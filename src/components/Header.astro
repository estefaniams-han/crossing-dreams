---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="deco-top">✦ &ensp; ✿ &ensp; ✦</div>

	<div class="masthead">
		<a href="/" class="site-name">{SITE_TITLE}</a>
		<p class="tagline">being better and fithing for a dream</p>
	</div>

	<nav>
		<HeaderLink href="/">home</HeaderLink>
		<span class="dot">·</span>
		<HeaderLink href="/blog">posts</HeaderLink>
		<span class="dot">·</span>
		<HeaderLink href="/about">about</HeaderLink>
		<span class="dot">·</span>
		<HeaderLink href="/search">search</HeaderLink>
	</nav>

	<button id="theme-toggle" class="theme-btn" aria-label="Toggle dark mode"></button>
	<button id="back-to-top" class="top-btn" aria-label="Back to top">
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
	</button>

	<div class="header-rule"></div>
</header>

<script is:inline>
	const btn = document.getElementById('theme-toggle');
	const updateIcon = () => {
		const dark = document.documentElement.getAttribute('data-theme') === 'dark';
		btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
		btn.innerHTML = dark
			? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>'
			: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
	};
	btn.addEventListener('click', () => {
		const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
		updateIcon();
	});
	updateIcon();

	// Back to top
	const topBtn = document.getElementById('back-to-top');
	window.addEventListener('scroll', () => {
		topBtn.classList.toggle('visible', window.scrollY > 400);
	});
	topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

<style>
	header {
		background: var(--bg);
		padding: 2rem 1.5rem 0;
		text-align: center;
	}

	.deco-top {
		font-size: 0.85em;
		color: var(--pink);
		letter-spacing: 0.4em;
		margin-bottom: 0.8rem;
	}

	.masthead {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		margin-bottom: 1.2rem;
	}

	.site-name {
		font-family: var(--font-script);
		font-size: clamp(2.6rem, 7vw, 4.8rem);
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
		line-height: 1.05;
	}
	.site-name:hover { color: var(--pink-dark); }

	.tagline {
		font-family: var(--font-body);
		font-size: 0.76em;
		font-weight: 300;
		letter-spacing: 0.2em;
		color: var(--text-light);
		margin: 0;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.7rem;
		margin-bottom: 1.5rem;
	}

	nav :global(a) {
		font-family: var(--font-body);
		font-size: 0.78em;
		font-weight: 500;
		letter-spacing: 0.12em;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s;
		padding-bottom: 0.1em;
	}

	nav :global(a:hover),
	nav :global(a.active) { color: var(--pink-dark); }

	nav :global(a.active) {
		border-bottom: 1.5px solid var(--pink);
	}

	.dot { color: var(--border); font-size: 0.9em; }

	.theme-btn {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 100;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		background: var(--white);
		border: 1px solid var(--border);
		box-shadow: var(--card-shadow-hover);
		cursor: pointer;
		color: var(--text-light);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s, transform 0.2s, box-shadow 0.2s;
	}
	.theme-btn:hover {
		color: var(--pink-dark);
		transform: translateY(-2px);
	}

	.top-btn {
		position: fixed;
		bottom: 5.5rem;
		right: 2rem;
		z-index: 100;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		background: var(--white);
		border: 1px solid var(--border);
		box-shadow: var(--card-shadow-hover);
		cursor: pointer;
		color: var(--text-light);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s, color 0.2s, transform 0.2s;
	}
	.top-btn.visible {
		opacity: 1;
		pointer-events: auto;
	}
	.top-btn:hover {
		color: var(--pink-dark);
		transform: translateY(-2px);
	}


	.header-rule {
		max-width: 960px;
		margin: 0 auto;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--border), transparent);
	}
</style>
