---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const prose = document.querySelector('.prose');
			if (!prose) return;

			const walker = document.createTreeWalker(
				prose,
				NodeFilter.SHOW_TEXT,
				{
					acceptNode(node) {
						if (node.parentElement?.closest('code, pre, a, h1, h2, h3, h4')) {
							return NodeFilter.FILTER_REJECT;
						}
						return node.textContent?.includes('(')
							? NodeFilter.FILTER_ACCEPT
							: NodeFilter.FILTER_REJECT;
					},
				}
			);

			const nodes = [];
			while (walker.nextNode()) nodes.push(walker.currentNode);

			nodes.forEach((node) => {
				const wrapper = document.createElement('span');
				wrapper.innerHTML = node.textContent.replace(
					/\(([^)]+)\)/g,
					'<span class="parenthetical">($1)</span>'
				);
				node.parentNode.replaceChild(wrapper, node);
			});
		});
	</script>
	<body>
		<Header />

		<main>
			<article>
				{heroImage && (
					<div class="hero-wrap">
						<Image
							width={1100}
							height={500}
							src={heroImage}
							alt={title}
							class="hero-img"
						/>
					</div>
				)}

				<div class="article-header">
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<a href={`/tags/${tag}`} class="tag">{tag}</a>
							))}
						</div>
					)}

					<h1 class="article-title">{title}</h1>
					<p class="article-desc">{description}</p>

					<div class="article-meta">
						<span class="meta"><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="meta">· updated: <FormattedDate date={updatedDate} /></span>
						)}
					</div>

					<div class="header-rule"></div>
				</div>

				<div class="prose" data-pagefind-body>
					<slot />
				</div>

				<Comments />

				<div class="article-footer">
					<div class="deco-line">✦ &ensp; ✿ &ensp; ✦</div>
					<a href="/blog" class="back-link">← back to posts</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1.5rem 4rem;
	}

	.hero-wrap {
		margin: 2.5rem 0 0;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--card-shadow-hover);
	}

	.hero-img {
		width: 100%;
		height: 400px;
		object-fit: cover;
		display: block;
	}

	.article-header {
		padding: 2.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

	.article-title {
		font-size: clamp(2em, 5vw, 3em);
		font-weight: 400;
		line-height: 1.15;
		margin: 0;
	}

	.article-desc {
		font-family: var(--font-heading);
		font-style: italic;
		font-size: 1.15em;
		color: var(--text-light);
		margin: 0;
		font-weight: 300;
	}

	.article-meta {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.header-rule {
		height: 1px;
		background: linear-gradient(90deg, var(--border), transparent);
		margin: 0.8rem 0 0;
	}

	.prose { padding-top: 2rem; }

	.article-footer {
		margin-top: 3.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.2rem;
	}

	.deco-line {
		font-size: 0.9em;
		color: var(--pink);
		letter-spacing: 0.4em;
	}

	.back-link {
		font-size: 0.8em;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--pink-dark); }
</style>
