---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
	.filter(post => {
		if (!tags || !post.data.tags) return false;
		if (post.data.title === title) return false;
		return post.data.tags.some((tag: string) => tags.includes(tag));
	})
	.slice(0, 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" pubDate={pubDate} tags={tags} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate,
			"keywords": tags?.join(', '),
			"author": {
				"@type": "Person",
				"name": "Tefi"
			}
		})} />
	</head>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const prose = document.querySelector('.prose');
			if (!prose) return;

			const walker = document.createTreeWalker(
				prose,
				NodeFilter.SHOW_TEXT,
				{
					acceptNode(node) {
						if (node.parentElement?.closest('code, pre, a, h1, h2, h3, h4')) {
							return NodeFilter.FILTER_REJECT;
						}
						return node.textContent?.includes('(')
							? NodeFilter.FILTER_ACCEPT
							: NodeFilter.FILTER_REJECT;
					},
				}
			);

			const nodes = [];
			while (walker.nextNode()) nodes.push(walker.currentNode);

			nodes.forEach((node) => {
				const wrapper = document.createElement('span');
				wrapper.innerHTML = node.textContent.replace(
					/\(([^)]+)\)/g,
					'<span class="parenthetical">($1)</span>'
				);
				node.parentNode.replaceChild(wrapper, node);
			});
		});
	</script>
	<body>
		<div id="progress-bar" class="progress-bar"></div>
		<Header />

		<main>
			<article>
				{heroImage && (
					<div class="hero-wrap">
						<Image
							width={1100}
							height={500}
							src={heroImage}
							alt={title}
							class="hero-img"
						/>
					</div>
				)}

				<div class="article-header">
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<a href={`/tags/${tag}`} class="tag">{tag}</a>
							))}
						</div>
					)}

					<h1 class="article-title">{title}</h1>
					<p class="article-desc">{description}</p>

					<div class="article-meta">
						<span class="meta"><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="meta">· updated: <FormattedDate date={updatedDate} /></span>
						)}
					</div>

					<div class="header-rule"></div>
				</div>

				<div class="prose" data-pagefind-body>
					<slot />
				</div>

				{related.length > 0 && (
					<div class="related">
						<p class="related-label">✦   you might also like</p>
						<div class="related-grid">
							{related.map(post => (
								<a href={`/blog/${post.id}/`} class="related-card">
									{post.data.heroImage && (
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={400}
											height={200}
											class="related-img"
										/>
									)}
									<div class="related-body">
										{post.data.tags && post.data.tags[0] && (
											<span class="related-tag">{post.data.tags[0]}</span>
										)}
										<p class="related-title">{post.data.title}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				)}

				<Comments />

				<div class="share-section">
					<p class="share-label">✦ &nbsp; share this post</p>
					<div class="share-btns">
						<a id="share-x" href="#" target="_blank" rel="noopener noreferrer" class="share-btn">share on X</a>
						<button id="copy-link" class="share-btn share-btn-ghost">copy link</button>
					</div>
				</div>

				<div class="article-footer">
					<div class="deco-line">✦ &ensp; ✿ &ensp; ✦</div>
					<a href="/blog" class="back-link">← back to posts</a>
				</div>
			</article>
		</main>
		<aside id="toc-container" class="toc-float" style="display:none;">
			<div class="toc-label">✦ &nbsp; in this post</div>
			<nav id="toc-nav"></nav>
		</aside>

		<Footer />
	</body>

	<script is:inline>
		// Table of contents — floating, auto-generated from h2s, shown only if 3+
		(function() {
			const prose = document.querySelector('.prose');
			const container = document.getElementById('toc-container');
			const nav = document.getElementById('toc-nav');
			if (!prose || !container || !nav) return;

			const headings = Array.from(prose.querySelectorAll('h2'));
			if (headings.length < 3) return;

			headings.forEach((h, i) => {
				if (!h.id) h.id = 'section-' + i;
				const a = document.createElement('a');
				a.href = '#' + h.id;
				const full = h.textContent || '';
				a.textContent = full;
				a.className = 'toc-link';
				a.dataset.target = h.id;
				nav.appendChild(a);
			});

			container.style.display = 'block';

			// Highlight active section on scroll
			const links = Array.from(nav.querySelectorAll('.toc-link'));
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						links.forEach(l => l.classList.remove('toc-active'));
						const active = links.find(l => l.dataset.target === entry.target.id);
						if (active) active.classList.add('toc-active');
					}
				});
			}, { rootMargin: '0px 0px -60% 0px' });

			headings.forEach(h => observer.observe(h));

			// Hide TOC once user scrolls past the end of article content
			const sentinel = document.querySelector('.related') || document.querySelector('.share-section');
			if (sentinel) {
				const threshold = sentinel.offsetTop - window.innerHeight * 0.5;
				function updateTocVisibility() {
					const past = window.scrollY >= threshold;
					container.style.opacity = past ? '0' : '1';
					container.style.pointerEvents = past ? 'none' : 'auto';
				}
				window.addEventListener('scroll', updateTocVisibility, { passive: true });
				updateTocVisibility();
			}
		})();

		// Reading progress bar
		const bar = document.getElementById('progress-bar');
		window.addEventListener('scroll', () => {
			const doc = document.documentElement;
			const pct = (window.scrollY / (doc.scrollHeight - doc.clientHeight)) * 100;
			bar.style.width = pct + '%';
		});

		// Share on X
		const shareX = document.getElementById('share-x');
		if (shareX) {
			const text = 'Found this on Crossing Dreams ✨ ' + document.title;
			shareX.href = 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.href) + '&text=' + encodeURIComponent(text);
		}

		// Copy link
		const copyBtn = document.getElementById('copy-link');
		if (copyBtn) {
			copyBtn.addEventListener('click', () => {
				navigator.clipboard.writeText(window.location.href).then(() => {
					const orig = copyBtn.textContent;
					copyBtn.textContent = 'copied!';
					setTimeout(() => copyBtn.textContent = orig, 2000);
				});
			});
		}
	</script>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1.5rem 4rem;
	}

	.hero-wrap {
		margin: 2.5rem 0 0;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--card-shadow-hover);
	}

	.hero-img {
		width: 100%;
		height: 400px;
		object-fit: cover;
		display: block;
	}

	.article-header {
		padding: 2.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

	.article-title {
		font-size: clamp(2em, 5vw, 3em);
		font-weight: 400;
		line-height: 1.15;
		margin: 0;
	}

	.article-desc {
		font-family: var(--font-heading);
		font-style: italic;
		font-size: 1.15em;
		color: var(--text-light);
		margin: 0;
		font-weight: 300;
	}

	.article-meta {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.header-rule {
		height: 1px;
		background: linear-gradient(90deg, var(--border), transparent);
		margin: 0.8rem 0 0;
	}

	.prose { padding-top: 2rem; }

	.article-footer {
		margin-top: 3.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.2rem;
	}

	.deco-line {
		font-size: 0.9em;
		color: var(--pink);
		letter-spacing: 0.4em;
	}

	.back-link {
		font-size: 0.8em;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--pink-dark); }

	.related {
		margin-top: 3.5rem;
	}

	.related-label {
		font-family: var(--font-body);
		font-size: 0.72em;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--pink-dark);
		margin: 0 0 1.2rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1rem;
	}

	.related-card {
		background: var(--white);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--card-shadow);
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.related-card:hover {
		box-shadow: var(--card-shadow-hover);
		transform: translateY(-3px);
	}

	.related-img {
		width: 100%;
		height: 120px;
		object-fit: cover;
		display: block;
	}

	.related-body {
		padding: 0.8rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.related-tag {
		font-family: var(--font-body);
		font-size: 0.68em;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: var(--pink-dark);
		text-transform: uppercase;
	}

	.related-title {
		font-family: var(--font-heading);
		font-size: 1em;
		color: var(--text);
		margin: 0;
		line-height: 1.3;
	}

	.toc-float {
		display: none;
		position: fixed;
		top: 50%;
		right: max(1rem, calc((100vw - 720px) / 2 - 190px));
		transform: translateY(-50%);
		width: 160px;
		padding: 1em 1.1em;
		background: var(--white);
		border: 1px solid var(--border);
		border-left: 3px solid var(--pink);
		border-radius: 12px;
		font-family: var(--font-body);
		box-shadow: var(--card-shadow);
		z-index: 100;
		overflow: visible;
		transition: opacity 0.25s;
	}

	@media (max-width: 1200px) {
		.toc-float { display: none !important; }
	}

	:global(.toc-label) {
		font-size: 0.62em;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--pink-dark);
		margin-bottom: 0.7em;
	}

	:global(#toc-nav) {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}

	:global(.toc-link) {
		font-size: 0.83em;
		color: var(--text-light);
		text-decoration: none;
		line-height: 1.4;
		transition: color 0.2s, border-color 0.2s;
		padding-left: 0.5em;
		border-left: 2px solid transparent;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	:global(.toc-link:hover) {
		color: var(--pink-dark);
		border-left-color: var(--pink);
	}
	:global(.toc-link.toc-active) {
		color: var(--pink-dark);
		border-left-color: var(--pink);
		font-weight: 600;
	}


	.progress-bar {
		position: fixed;
		top: 0;
		left: 0;
		height: 3px;
		width: 0%;
		background: linear-gradient(90deg, var(--pink), var(--pink-dark));
		z-index: 9999;
		transition: width 0.1s linear;
		border-radius: 0 2px 2px 0;
	}

	.share-section {
		margin-top: 3rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.share-label {
		font-family: var(--font-body);
		font-size: 0.72em;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--pink-dark);
		margin: 0;
	}

	.share-btns {
		display: flex;
		gap: 0.8rem;
	}

	.share-btn {
		font-family: var(--font-body);
		font-size: 0.82em;
		font-weight: 600;
		padding: 0.55em 1.4em;
		border-radius: 30px;
		background: var(--pink-dark);
		color: var(--white);
		text-decoration: none;
		border: none;
		cursor: pointer;
		transition: background 0.2s, transform 0.2s;
	}
	.share-btn:hover { background: #a84f6a; color: var(--white); transform: translateY(-2px); }

	.share-btn-ghost {
		background: transparent;
		border: 1.5px solid var(--pink-dark);
		color: var(--pink-dark);
	}
	.share-btn-ghost:hover { background: var(--pink-soft); color: var(--pink-dark); transform: translateY(-2px); }
</style>
