---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
	.filter(post => {
		if (!tags || !post.data.tags) return false;
		if (post.data.title === title) return false;
		return post.data.tags.some((tag: string) => tags.includes(tag));
	})
	.slice(0, 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const prose = document.querySelector('.prose');
			if (!prose) return;

			const walker = document.createTreeWalker(
				prose,
				NodeFilter.SHOW_TEXT,
				{
					acceptNode(node) {
						if (node.parentElement?.closest('code, pre, a, h1, h2, h3, h4')) {
							return NodeFilter.FILTER_REJECT;
						}
						return node.textContent?.includes('(')
							? NodeFilter.FILTER_ACCEPT
							: NodeFilter.FILTER_REJECT;
					},
				}
			);

			const nodes = [];
			while (walker.nextNode()) nodes.push(walker.currentNode);

			nodes.forEach((node) => {
				const wrapper = document.createElement('span');
				wrapper.innerHTML = node.textContent.replace(
					/\(([^)]+)\)/g,
					'<span class="parenthetical">($1)</span>'
				);
				node.parentNode.replaceChild(wrapper, node);
			});
		});
	</script>
	<body>
		<Header />

		<main>
			<article>
				{heroImage && (
					<div class="hero-wrap">
						<Image
							width={1100}
							height={500}
							src={heroImage}
							alt={title}
							class="hero-img"
						/>
					</div>
				)}

				<div class="article-header">
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<a href={`/tags/${tag}`} class="tag">{tag}</a>
							))}
						</div>
					)}

					<h1 class="article-title">{title}</h1>
					<p class="article-desc">{description}</p>

					<div class="article-meta">
						<span class="meta"><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="meta">· updated: <FormattedDate date={updatedDate} /></span>
						)}
					</div>

					<div class="header-rule"></div>
				</div>

				<div class="prose" data-pagefind-body>
					<slot />
				</div>

				{related.length > 0 && (
					<div class="related">
						<p class="related-label">✦   you might also like</p>
						<div class="related-grid">
							{related.map(post => (
								<a href={} class="related-card">
									{post.data.heroImage && (
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={400}
											height={200}
											class="related-img"
										/>
									)}
									<div class="related-body">
										{post.data.tags && post.data.tags[0] && (
											<span class="related-tag">{post.data.tags[0]}</span>
										)}
										<p class="related-title">{post.data.title}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				)}

				<Comments />

				<div class="article-footer">
					<div class="deco-line">✦ &ensp; ✿ &ensp; ✦</div>
					<a href="/blog" class="back-link">← back to posts</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1.5rem 4rem;
	}

	.hero-wrap {
		margin: 2.5rem 0 0;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--card-shadow-hover);
	}

	.hero-img {
		width: 100%;
		height: 400px;
		object-fit: cover;
		display: block;
	}

	.article-header {
		padding: 2.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

	.article-title {
		font-size: clamp(2em, 5vw, 3em);
		font-weight: 400;
		line-height: 1.15;
		margin: 0;
	}

	.article-desc {
		font-family: var(--font-heading);
		font-style: italic;
		font-size: 1.15em;
		color: var(--text-light);
		margin: 0;
		font-weight: 300;
	}

	.article-meta {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.header-rule {
		height: 1px;
		background: linear-gradient(90deg, var(--border), transparent);
		margin: 0.8rem 0 0;
	}

	.prose { padding-top: 2rem; }

	.article-footer {
		margin-top: 3.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.2rem;
	}

	.deco-line {
		font-size: 0.9em;
		color: var(--pink);
		letter-spacing: 0.4em;
	}

	.back-link {
		font-size: 0.8em;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--pink-dark); }

	.related {
		margin-top: 3.5rem;
	}

	.related-label {
		font-family: var(--font-body);
		font-size: 0.72em;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--pink-dark);
		margin: 0 0 1.2rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1rem;
	}

	.related-card {
		background: var(--white);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--card-shadow);
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.related-card:hover {
		box-shadow: var(--card-shadow-hover);
		transform: translateY(-3px);
	}

	.related-img {
		width: 100%;
		height: 120px;
		object-fit: cover;
		display: block;
	}

	.related-body {
		padding: 0.8rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.related-tag {
		font-family: var(--font-body);
		font-size: 0.68em;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: var(--pink-dark);
		text-transform: uppercase;
	}

	.related-title {
		font-family: var(--font-heading);
		font-size: 1em;
		color: var(--text);
		margin: 0;
		line-height: 1.3;
	}
</style>
