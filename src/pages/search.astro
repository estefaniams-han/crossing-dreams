---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Search — ${SITE_TITLE}`} description="Search all posts on Crossing Dreams." />
		<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
	</head>
	<body>
		<Header />

		<main class="main">
			<div class="search-header">
				<span class="deco">✦</span>
				<h1>Search</h1>
			</div>

			<div id="search"></div>
		</main>

		<Footer />

		<script is:inline>
			var s = document.createElement('script');
			s.src = '/pagefind/pagefind-ui.js';
			s.onload = function () {
				// @ts-ignore
				new PagefindUI({
					element: '#search',
					showSubResults: true,
					showImages: true,
					resetStyles: false,
				});
			};
			document.head.appendChild(s);
		</script>
	</body>
</html>

<style>
	.main {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.search-header {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.search-header h1 {
		font-size: 2.6em;
		font-weight: 300;
		margin: 0;
	}

	.deco { color: var(--pink); font-size: 1em; }

	/* ── Override Pagefind styles to match our palette ── */
	#search,
	#search * {
		text-align: left !important;
	}

	#search {
		--pagefind-ui-scale: 1;
		--pagefind-ui-primary: var(--pink-dark);
		--pagefind-ui-text: var(--text);
		--pagefind-ui-background: var(--white);
		--pagefind-ui-border: var(--border);
		--pagefind-ui-tag: var(--pink-soft);
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 12px;
		--pagefind-ui-image-border-radius: 12px;
		--pagefind-ui-font: var(--font-body);
	}

	/* Input */
	#search :global(.pagefind-ui__search-input) {
		border-radius: 30px !important;
		border-color: var(--border) !important;
		background: var(--white) !important;
		font-family: var(--font-body) !important;
		font-size: 1em !important;
		padding: 0.7em 1.4em !important;
		box-shadow: var(--card-shadow) !important;
		transition: box-shadow 0.2s, border-color 0.2s !important;
	}
	#search :global(.pagefind-ui__search-input:focus) {
		outline: none !important;
		border-color: var(--pink) !important;
		box-shadow: 0 0 0 3px rgba(240, 160, 184, 0.2) !important;
	}

	/* Search button */
	#search :global(.pagefind-ui__search-clear) {
		color: var(--text-light) !important;
	}

	/* Results */
	#search :global(.pagefind-ui__result) {
		background: var(--white) !important;
		border: 1px solid var(--border-soft) !important;
		border-radius: 16px !important;
		padding: 1.2rem 1.4rem !important;
		margin-bottom: 1rem !important;
		box-shadow: var(--card-shadow) !important;
		transition: box-shadow 0.2s, transform 0.2s !important;
	}
	#search :global(.pagefind-ui__result:hover) {
		box-shadow: var(--card-shadow-hover) !important;
		transform: translateY(-2px) !important;
	}

	#search :global(.pagefind-ui__result-inner) {
		text-align: left !important;
	}

	#search :global(.pagefind-ui__result-title) {
		text-align: left !important;
	}

	#search :global(.pagefind-ui__result-title a) {
		font-family: var(--font-heading) !important;
		font-size: 1.3em !important;
		color: var(--text) !important;
		text-decoration: none !important;
	}
	#search :global(.pagefind-ui__result-title a:hover) {
		color: var(--pink-dark) !important;
	}

	#search :global(.pagefind-ui__result-excerpt) {
		font-size: 0.88em !important;
		color: var(--text-light) !important;
		line-height: 1.65 !important;
		text-align: left !important;
	}

	#search :global(.pagefind-ui__result-image) {
		display: none !important;
	}

	#search :global(mark) {
		background: var(--pink-soft) !important;
		color: var(--pink-dark) !important;
		border-radius: 3px !important;
		padding: 0 2px !important;
	}
</style>
