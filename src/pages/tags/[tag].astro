---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];

	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((p) => p.data.tags?.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props;
const readTime = (body: string) => Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`#${tag} — ${SITE_TITLE}`}
			description={`All posts tagged with "${tag}"`}
		/>
	</head>
	<body>
		<Header />

		<main class="main">
			<div class="page-header">
				<p class="back"><a href="/blog">← all posts</a></p>
				<div class="tag-hero">
					<span class="tag-badge">#{tag}</span>
					<h1 class="page-title">{posts.length} {posts.length === 1 ? 'story' : 'stories'}</h1>
				</div>
			</div>

			<div class="cards-grid">
				{posts.map((post) => (
					<article class="card">
						{post.data.heroImage && (
							<a href={`/blog/${post.id}/`} class="card-img-link">
								{post.data.tags && post.data.tags[0] && (
									<span class="card-cat">{post.data.tags[0]}</span>
								)}
								<Image
									width={420}
									height={240}
									src={post.data.heroImage}
									alt={post.data.title}
									class="card-img"
								/>
							</a>
						)}
						<div class="card-body">
							<div class="card-meta">
								<span class="meta"><FormattedDate date={post.data.pubDate} /></span>
								<span class="meta">· {readTime(post.body ?? '')} min read</span>
							</div>
							<h3 class="card-title">
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</h3>
							<p class="card-desc">{post.data.description}</p>
							<div class="tags">
								{post.data.tags?.map((t: string) => (
									<a href={`/tags/${t}`} class="tag">{t}</a>
								))}
							</div>
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.main {
		max-width: 980px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.page-header { display: flex; flex-direction: column; gap: 1rem; }

	.back {
		font-size: 0.8em;
		font-weight: 600;
		letter-spacing: 0.06em;
		margin: 0;
	}
	.back a { color: var(--text-light); }
	.back a:hover { color: var(--pink-dark); }

	.tag-hero {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		flex-wrap: wrap;
	}

	.tag-badge {
		font-family: var(--font-script);
		font-size: 2em;
		color: var(--pink-dark);
	}

	.page-title {
		font-size: 1.6em;
		font-weight: 300;
		color: var(--text-light);
		margin: 0;
	}

	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.8rem;
	}

	.card {
		background: var(--white);
		border-radius: 20px;
		overflow: hidden;
		box-shadow: var(--card-shadow);
		transition: box-shadow 0.3s ease, transform 0.3s ease;
		display: flex;
		flex-direction: column;
	}
	.card:hover { box-shadow: var(--card-shadow-hover); transform: translateY(-4px); }

	.card-img-link { display: block; position: relative; overflow: hidden; }
	.card-img {
		width: 100%; height: 200px; object-fit: cover; display: block;
		transition: transform 0.4s ease;
	}
	.card-img-link:hover .card-img { transform: scale(1.05); }

	.card-cat {
		position: absolute; top: 10px; left: 10px;
		background: var(--pink-dark); color: var(--white);
		font-size: 0.68em; font-weight: 700; font-family: var(--font-body);
		letter-spacing: 0.06em; padding: 3px 12px; border-radius: 20px; z-index: 1;
	}

	.card-body {
		padding: 1.1rem 1.3rem 1.4rem;
		display: flex; flex-direction: column; gap: 0.5rem; flex: 1;
	}

	.card-meta { display: flex; gap: 0.3rem; flex-wrap: wrap; }

	.card-title { font-size: 1.15em; margin: 0; line-height: 1.3; }
	.card-title a { color: var(--text); }
	.card-title a:hover { color: var(--pink-dark); }

	.card-desc { font-size: 0.85em; color: var(--text-light); margin: 0; line-height: 1.6; flex: 1; }

	.tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.2rem; }

	@media (max-width: 720px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 480px) { .cards-grid { grid-template-columns: 1fr; } }
</style>
